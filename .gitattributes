# Normalise line endings: store text as LF in the repo, check out native.
* text=auto

# Keep these as LF everywhere (avoids CRLF churn across machines).
*.py   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Treat model weights and media as binary (never line-ending munged or diffed).
*.pt  binary
*.onnx binary
*.tflite binary
*.mp4 binary
*.avi binary
*.mov binary
*.jpg binary
*.jpeg binary
*.png binary
*.db  binary
