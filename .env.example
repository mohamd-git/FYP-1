# =============================================================================
# .env.example -- copy this to ".env" and fill in values. NEVER commit ".env".
#   PowerShell:  Copy-Item .env.example .env
# =============================================================================

# --- MQTT authentication -----------------------------------------------------
# For this PoC the local Mosquitto broker and the public HiveMQ fallback both
# accept ANONYMOUS connections, so you may leave these BLANK. Fill them in only
# if you point config.yaml at a broker that requires a login.
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Flask dashboard ---------------------------------------------------------
# Session-signing key for the dashboard. Any random string is fine locally.
FLASK_SECRET_KEY=change-me-to-any-random-string

# Notes:
#  * config.yaml holds all NON-secret settings (paths, thresholds, topics).
#  * Add future SECRETS here as named placeholders only -- never paste a real
#    key, token or password into a tracked file.
